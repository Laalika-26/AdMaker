{
  "version": 2,
  "name": "admaker-engine",
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "landing.css", "use": "@vercel/static" },
    { "src": "landing.js", "use": "@vercel/static" },
    { "src": "app.html", "use": "@vercel/static" },
    { "src": "app.css", "use": "@vercel/static" },
    { "src": "app.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
